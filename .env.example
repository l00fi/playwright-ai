OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_MODEL=openai/gpt-4o

# Runtime limits
AGENT_MAX_TOTAL_STEPS=45
AGENT_MAX_STEPS_PER_SUBTASK=10
AGENT_MAX_RESTARTS_PER_SUBTASK=2
AGENT_LOOP_REPEAT_THRESHOLD=3
AGENT_MAX_SNAPSHOT_FAIL_STREAK=5
AGENT_LANGGRAPH_RECURSION_LIMIT=200
AGENT_MAX_REPLANS=2

# Snapshot tuning (optional)
AGENT_SNAPSHOT_LOAD_WAIT_MS=8000
AGENT_SNAPSHOT_MUTATION_WAIT_MS=6000
AGENT_SNAPSHOT_MUTATION_IDLE_MS=500
AGENT_SNAPSHOT_FALLBACK_SETTLE_MS=350